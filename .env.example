# Copy this file to `.env` and fill in your real values.
# `.env` is git-ignored and must never be shared or committed.

# Webhook auth — any long random string; the caller must send it as X-Webhook-Secret
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Google Gemini (LLM) — get a free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Gmail (auto-reply email)
GMAIL_ADDRESS=your-gmail-address@gmail.com
# 16-char Gmail APP PASSWORD (Google Account -> Security -> App passwords), NOT your login password
GMAIL_APP_PASSWORD=your-16-char-app-password

# Odoo CRM (XML-RPC external API)
ODOO_URL=https://your-db.odoo.com
ODOO_DB=your-db
ODOO_USERNAME=your-odoo-login-email@example.com
ODOO_API_KEY=your-odoo-api-key

# Integration modes:  "mock" or "live" 
LLM_MODE=live
EMAIL_MODE=live
ODOO_MODE=live